{
  "name": "text-share",
  "version": "0.1.0",
  "private": true,
  "description": "Password-protected Cloudflare Worker sharing board for Markdown text and documents.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply text-share --local",
    "db:migrate:remote": "wrangler d1 migrations apply text-share --remote"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260702.1",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4",
    "wrangler": "^4.24.3"
  }
}
